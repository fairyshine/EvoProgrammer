#!/bin/sh
# shellcheck shell=bash

. "$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)/lib/bootstrap.sh"
evop_exec_with_preferred_shell "$0" "$@"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname -- "$0")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
EVOP_LIB_DIR="$ROOT_DIR/lib"
MAIN_SCRIPT="$ROOT_DIR/MAIN.sh"
LOOP_SCRIPT="$ROOT_DIR/LOOP.sh"
DOCTOR_SCRIPT="$ROOT_DIR/DOCTOR.sh"
INSPECT_SCRIPT="$ROOT_DIR/INSPECT.sh"
VERIFY_SCRIPT="$ROOT_DIR/VERIFY.sh"
CLEAN_SCRIPT="$ROOT_DIR/CLEAN.sh"
STATUS_SCRIPT="$ROOT_DIR/STATUS.sh"
COMMON_LIB="$ROOT_DIR/lib/common.sh"
VERSION_LIB="$ROOT_DIR/lib/version.sh"

source "$COMMON_LIB"
source "$VERSION_LIB"

usage() {
    cat <<'EOF'
Usage:
  EvoProgrammer [global-options] [prompt]
  EvoProgrammer [global-options] once [options] [prompt]
  EvoProgrammer [global-options] doctor [options]
  EvoProgrammer [global-options] inspect [options]
  EvoProgrammer [global-options] verify [options]
  EvoProgrammer [global-options] clean [options]
  EvoProgrammer [global-options] status [options]
  EvoProgrammer help

Default behavior:
  Run the selected coding agent in the current directory and keep iterating until stopped.

Subcommands:
  once    Run a single agent iteration in the current directory.
  doctor  Validate local prerequisites and target directory wiring.
  inspect Print the detected repo language/framework/project context and command plan.
  verify  Run the detected verification commands for the target repo.
  clean   Remove old run artifacts from the target directory.
  status  Show recent run and session history from the target directory.
  help    Show this help text.

Examples:
  EvoProgrammer "生成一个带登录和支付的 SaaS 项目"
  EvoProgrammer --max-iterations 3 "build a Next.js app with Stripe"
  EvoProgrammer --language rust --framework bevy --project-type online-game "build the dedicated server first"
  EvoProgrammer --language gdscript --framework godot --project-type single-player-game "build the first playable loop"
  EvoProgrammer --artifacts-dir /tmp/evop-runs "improve the repo architecture"
  EvoProgrammer --agent claude once --agent-args '["--model","sonnet"]' "scaffold tests"
  EvoProgrammer once --agent-args '["--model","gpt-5"]' "scaffold tests"
  EvoProgrammer doctor --target-dir /path/to/project
  EvoProgrammer inspect --target-dir /path/to/project --format summary
  EvoProgrammer verify --target-dir /path/to/project --steps lint,test
  EvoProgrammer clean --target-dir /path/to/project --older-than 7 --dry-run
  EvoProgrammer status --target-dir /path/to/project --last 5

Use 'EvoProgrammer help' for the wrapper, './MAIN.sh --help' for loop options,
 './LOOP.sh --help' for single-run options, './DOCTOR.sh --help'
for environment checks, './INSPECT.sh --help' for repo inspection, and
 './VERIFY.sh --help' for command verification, './CLEAN.sh --help' for
artifact cleanup, and './STATUS.sh --help' for run history.
EOF
}

find_subcommand() {
    local expecting_value=0
    local index=0
    local arg

    EVOP_CLI_SUBCOMMAND=""
    EVOP_CLI_SUBCOMMAND_INDEX=0

    for arg in "$@"; do
        index=$((index + 1))

        if (( expecting_value == 1 )); then
            expecting_value=0
            continue
        fi

        case "$arg" in
            --)
                break
                ;;
            -g|--agent|--language|--framework|--project-type|-p|--prompt|-f|--prompt-file|-t|--target-dir|-o|--artifacts-dir|--context-file|-n|--max-iterations|-d|--delay-seconds|--agent-args|-a|--agent-arg|--codex-arg)
                expecting_value=1
                ;;
            -c|--continue-on-error|--dry-run|-q|--quiet|-v|--verbose)
                # flags without values
                ;;
            help|-h|--help)
                EVOP_CLI_SUBCOMMAND="help"
                EVOP_CLI_SUBCOMMAND_INDEX="$index"
                return 0
                ;;
            version|--version)
                EVOP_CLI_SUBCOMMAND="version"
                EVOP_CLI_SUBCOMMAND_INDEX="$index"
                return 0
                ;;
            once|doctor|inspect|verify|clean|status)
                EVOP_CLI_SUBCOMMAND="$arg"
                EVOP_CLI_SUBCOMMAND_INDEX="$index"
                return 0
                ;;
            -*)
                ;;
            *)
                break
                ;;
        esac
    done

    return 1
}

build_forwarded_args() {
    local skip_index="$1"
    shift
    local index=0
    local arg

    EVOP_FORWARDED_ARGS=()

    for arg in "$@"; do
        index=$((index + 1))
        if (( index == skip_index )); then
            continue
        fi
        EVOP_FORWARDED_ARGS+=("$arg")
    done
}

evop_require_executable_file "$MAIN_SCRIPT" "Main script"
evop_require_executable_file "$LOOP_SCRIPT" "Loop script"
evop_require_executable_file "$DOCTOR_SCRIPT" "Doctor script"
evop_require_executable_file "$INSPECT_SCRIPT" "Inspect script"
evop_require_executable_file "$VERIFY_SCRIPT" "Verify script"
evop_require_executable_file "$CLEAN_SCRIPT" "Clean script"
evop_require_executable_file "$STATUS_SCRIPT" "Status script"

find_subcommand "$@" || true

case "${EVOP_CLI_SUBCOMMAND:-}" in
    help)
        usage
        ;;
    version)
        printf 'EvoProgrammer %s\n' "$EVOPROGRAMMER_VERSION"
        ;;
    once)
        build_forwarded_args "$EVOP_CLI_SUBCOMMAND_INDEX" "$@"
        exec "$LOOP_SCRIPT" "${EVOP_FORWARDED_ARGS[@]}"
        ;;
    doctor)
        build_forwarded_args "$EVOP_CLI_SUBCOMMAND_INDEX" "$@"
        exec "$DOCTOR_SCRIPT" "${EVOP_FORWARDED_ARGS[@]}"
        ;;
    inspect)
        build_forwarded_args "$EVOP_CLI_SUBCOMMAND_INDEX" "$@"
        exec "$INSPECT_SCRIPT" "${EVOP_FORWARDED_ARGS[@]}"
        ;;
    verify)
        build_forwarded_args "$EVOP_CLI_SUBCOMMAND_INDEX" "$@"
        exec "$VERIFY_SCRIPT" "${EVOP_FORWARDED_ARGS[@]}"
        ;;
    clean)
        build_forwarded_args "$EVOP_CLI_SUBCOMMAND_INDEX" "$@"
        exec "$CLEAN_SCRIPT" "${EVOP_FORWARDED_ARGS[@]}"
        ;;
    status)
        build_forwarded_args "$EVOP_CLI_SUBCOMMAND_INDEX" "$@"
        exec "$STATUS_SCRIPT" "${EVOP_FORWARDED_ARGS[@]}"
        ;;
    *)
        exec "$MAIN_SCRIPT" "$@"
        ;;
esac
